.DS_Store
dist
node_modules

# Generated by scripts/sync-python.mjs before each dev/build. The Python
# sources live under ../python/ — do not edit anything inside this dir,
# and do not check it in.
public/wingfont/

# Generated by scripts/sync-python.mjs alongside public/wingfont/. The
# Pyodide worker imports this JSON to know which .py modules to copy
# into its virtual filesystem. The source of truth is the MANIFEST in
# scripts/sync-python.mjs — do not edit by hand.
src/workers/pyodideFiles.generated.json

# `public/fonts/` is no longer needed locally — the build-fonts.yml CI
# workflow publishes fonts directly to gh-pages /fonts/ on every push
# that touches python/**. `yarn deploy` ignores this directory via the
# `--add` flag (it adds/updates files but never wipes paths it doesn't
# touch), so even if you stage fonts here locally they wouldn't be
# pushed by yarn deploy. Kept in the ignore list anyway in case you
# want to drop test fonts here without staining the repo.
public/fonts/

# Vite cache + transient logs
.vite/
yarn-error.log
