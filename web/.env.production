# Base URL for the font CDN. Source-of-truth — consumers (utils/const.ts,
# FonttHeader.tsx) build per-font URLs as `${VITE_FONT_URL}/${family}.${format}`,
# so the `/fonts` path segment lives here rather than at the call sites.
# Fonts are deployed to gh-pages under `/fonts/` so they sit alongside
# the React app under a single domain (wing-font.chunlaw.io) without
# colliding with React asset paths.
VITE_FONT_URL=https://wing-font.chunlaw.io/fonts
