{
  "name": "wing-font-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-python.mjs",
    "dev": "yarn sync && vite",
    "build": "yarn sync && tsc && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "predeploy": "yarn build",
    "//deploy": "Publishes the React app to the ROOT of gh-pages. The `--add` flag means we only add/update files and never remove anything we didn't touch — critical because the build-fonts.yml CI workflow publishes fonts under /fonts/ on the same branch. Without --add, every deploy would wipe the /fonts/ subfolder right after CI populated it.",
    "deploy": "gh-pages -d dist --add"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.8",
    "file-saver": "^2.0.5",
    "fontkit": "^2.0.4",
    "jszip": "^3.10.1",
    "lodash.debounce": "^4.0.8",
    "opentype.js": "^1.3.4",
    "papaparse": "^5.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.2",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/fontkit": "^2.0.7",
    "@types/lodash.debounce": "^4.0.9",
    "@types/opentype.js": "^1.3.8",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "eslint": "^8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "gh-pages": "^6.0.0",
    "prettier": "^3.0.2",
    "typescript": "^5.0.2",
    "vite": "^5.1.5",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pwa": "^0.19.2"
  }
}
